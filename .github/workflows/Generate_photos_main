name: Generate_photos_main.json

on:
  push:
    branches: [main]
    paths:
      - 'Gallery_main/**'
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Generate_photos_main.json
        run: |
          python3 - << 'PYEOF'
          import os, json

          PHOTO_DIR = "Gallery_main"
          REPO = os.environ.get("GITHUB_REPOSITORY", "")
          RAW_BASE = "https://raw.githubusercontent.com/" + REPO + "/main/" + PHOTO_DIR
          IMG_EXT = {".jpg", ".jpeg", ".png", ".webp", ".gif"}

          result = []

          if os.path.isdir(PHOTO_DIR):
              # Якщо є підпапки — читаємо по підпапках (кафедри)
              subdirs = [d for d in sorted(os.listdir(PHOTO_DIR))
                         if os.path.isdir(os.path.join(PHOTO_DIR, d))]

              if subdirs:
                  for dept in subdirs:
                      dept_path = os.path.join(PHOTO_DIR, dept)
                      files = []
                      for fname in sorted(os.listdir(dept_path)):
                          if os.path.splitext(fname)[1].lower() in IMG_EXT:
                              files.append(fname)
                      if files:
                          result.append({
                              "dept": dept,
                              "base": RAW_BASE + "/" + dept,
                              "files": files
                          })
              else:
                  # Немає підпапок — всі фото в корені Gallery_main/
                  files = []
                  for fname in sorted(os.listdir(PHOTO_DIR)):
                      if os.path.splitext(fname)[1].lower() in IMG_EXT:
                          files.append(fname)
                  if files:
                      result.append({
                          "dept": "Загальні",
                          "base": RAW_BASE,
                          "files": files
                      })

          with open("photos_main.json", "w", encoding="utf-8") as f:
              json.dump(result, f, ensure_ascii=False, indent=2)

          total = sum(len(d["files"]) for d in result)
          print("Згенеровано photos_main.json: " + str(len(result)) + " груп, " + str(total) + " фото")
          PYEOF

      - name: Commit photos_main.json
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add photos_main.json
          git diff --cached --quiet || git commit -m "chore: update photos_main.json [skip ci]"
          git push
